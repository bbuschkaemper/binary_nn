// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
    "name": "Binary NN Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "devcontainer",
    "workspaceFolder": "/workspaces/binary_nn",
    "remoteUser": "root",
    "customizations": {
        "vscode": {
            "extensions": [
                "DavidAnson.vscode-markdownlint",
                "ms-vscode.live-server",
                "ms-python.python",
                "mechatroner.rainbow-csv",
                "ms-python.black-formatter",
                "ms-python.isort",
                "ms-toolsai.jupyter",
                "GitHub.copilot-chat"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspaces/binary_nn/.venv/bin/python",
                "python.terminal.activateEnvInCurrentTerminal": true,
                "extensions.verifySignature": false,
                "remote.downloadExtensionsLocally": true
            }
        }
    },
    "containerEnv": {
        "HF_HOME": "/mnt/data/huggingface/.huggingface",
        "UV_LINK_MODE": "copy"
    },
    "postStartCommand": "uv sync --locked --no-dev"
}